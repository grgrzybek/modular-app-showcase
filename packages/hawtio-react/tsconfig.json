{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    /* Language and Environment */
    "target": "es2024",
    "lib": [ "DOM", "ESNext" ],
    "jsx": "react-jsx",

    /* Modules */
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* JavaScript Support */
    "allowJs": false,

    /* Emit */
    "declaration": true,
    "declarationDir": "dist/dts",
    "emitDeclarationOnly": true,
    "noEmit": true,

    /* Interop Constraints */
    "isolatedModules": true,
    "esModuleInterop": true,

    /* Type Checking */
    "strict": true,
  },
  "include": [ "src" ]
}
